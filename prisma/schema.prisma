generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Post {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  content         String
  excerpt         String?
  coverImage      String?
  category        String   @default("Market Insight")
  isPublished     Boolean  @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Media {
  id         String   @id @default(uuid())
  filename   String
  url        String
  uploadedAt DateTime @default(now())
}

model Insight {
  id          String   @id @default(uuid())
  title       String
  description String
  externalUrl String
  coverImage  String?
  publisher   String   @default("External")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
